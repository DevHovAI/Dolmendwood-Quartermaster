<div class="item-row {{#if item.isSecret}}is-secret{{/if}}" data-item-id="{{item.id}}">
  <span class="item-name">
    {{#if item.isSecret}}
    <i class="fas fa-lock secret-icon" title="Secret item"></i>
    {{else if item.def}}
    <i class="fas {{itemIcon item.def.category}} item-cat-icon" title="{{item.def.category}}"></i>
    {{else}}
    <i class="fas {{#if item.customDefinition.icon}}{{item.customDefinition.icon}}{{else}}fa-sack{{/if}} item-cat-icon" title="Custom item"></i>
    {{/if}}
    {{item.name}}
    {{#if (eq encMode "weight")}}
      {{#if item.def}}
      <span class="item-size-badge item-weight-badge" title="Weight per unit">{{item.def.weight}} wt</span>
      {{else if item.customDefinition}}
      <span class="item-size-badge item-weight-badge" title="Weight per unit">{{#if item.customDefinition.weight}}{{item.customDefinition.weight}}{{else}}0{{/if}} wt</span>
      {{/if}}
    {{else}}
      {{#if item.def}}
      <span class="item-size-badge size-{{item.def.size}}" title="{{slotCost item.def.size}}">{{sizeLabel item.def.size}}</span>
      {{else if item.customDefinition.size}}
      <span class="item-size-badge size-{{item.customDefinition.size}}" title="{{slotCost item.customDefinition.size}}">{{sizeLabel item.customDefinition.size}}</span>
      {{/if}}
    {{/if}}
    {{#if item.def.cannotBeStowed}}<span class="badge badge-cannot-stow" title="Cannot be stowed">Carried</span>{{/if}}
    {{#if item.def.description}}<span class="item-description">{{item.def.description}}</span>{{/if}}
    {{#if item.customDefinition.description}}<span class="item-description">{{item.customDefinition.description}}</span>{{/if}}
  </span>

  {{#if canEdit}}
  <div class="item-qty-controls">
    <button type="button" data-action="decrementQty" data-item-id="{{item.id}}" class="qty-btn">−</button>
    <span class="item-qty">{{item.quantity}}</span>
    <button type="button" data-action="incrementQty" data-item-id="{{item.id}}" class="qty-btn">+</button>
  </div>
  {{else}}
  <span class="item-qty-readonly">×{{item.quantity}}</span>
  {{/if}}

  {{#if item.def.coinCapacity}}
  <div class="item-coin-capacity" title="Coins stored in this container">
    <i class="fas fa-coins" style="font-size:0.8em;opacity:0.6;"></i>
    <span class="coin-capacity-val">{{item.coinsStored}}/{{item.def.coinCapacity}}</span>
  </div>
  {{/if}}

  {{#if item.def.maxUses}}
  <div class="item-uses-controls">
    {{#if isOwner}}
    <button type="button" data-action="decrementUses" data-item-id="{{item.id}}"
            class="qty-btn" title="Use one" {{#if (eq item.uses 0)}}disabled{{/if}}>−</button>
    {{/if}}
    <span class="item-uses {{#if (eq item.uses 0)}}uses-empty{{/if}}"
          title="{{item.uses}} / {{item.def.maxUses}} remaining">{{item.uses}}/{{item.def.maxUses}}</span>
    {{#if isOwner}}
    <button type="button" data-action="incrementUses" data-item-id="{{item.id}}"
            class="qty-btn" title="Restore one" {{#if (eq item.uses item.def.maxUses)}}disabled{{/if}}>+</button>
    {{/if}}
  </div>
  {{/if}}

  {{#if isOwner}}
  <select class="item-zone-select" data-item-id="{{item.id}}" title="Move to zone">
    {{#if (eq encMode "weight")}}
    <option value="equipped" {{#if (eq item.zone "equipped")}}selected{{/if}}>Equipped</option>
    {{#each extraZones}}
    {{!-- Show belt pouch zones only if item fits (≤ 10 wt) or item is already in this zone --}}
    {{#if (or (eq ../item.zone this.id) (or (not this.isBeltPouch) (canUseTinyZone ../item ../encMode)))}}
    <option value="{{this.id}}" {{#if (eq ../item.zone this.id)}}selected{{/if}}>{{this.name}}</option>
    {{/if}}
    {{/each}}
    {{else}}
    {{#if (or (canUseTinyZone item encMode) (eq item.zone "tiny"))}}
    <option value="tiny" {{#if (eq item.zone "tiny")}}selected{{/if}}>Belt Pouch</option>
    {{/if}}
    <option value="equipped" {{#if (eq item.zone "equipped")}}selected{{/if}}>Equipped</option>
    <option value="stowed" {{#if (eq item.zone "stowed")}}selected{{/if}}>Stowed</option>
    {{#each extraZones}}
    <option value="{{this.id}}" {{#if (eq ../item.zone this.id)}}selected{{/if}}>{{this.name}}</option>
    {{/each}}
    {{/if}}
  </select>

  <textarea class="item-notes-input" data-item-id="{{item.id}}"
            placeholder="Notes…" title="Notes" rows="2">{{item.notes}}</textarea>
  {{/if}}

  {{#if isOwner}}
  <button type="button" data-action="toggleSecret" data-item-id="{{item.id}}"
          class="icon-btn secret-btn" title="{{#if item.isSecret}}Make visible{{else}}Make secret{{/if}}">
    <i class="fas {{#if item.isSecret}}fa-eye-slash{{else}}fa-eye{{/if}}"></i>
  </button>
  {{/if}}

  {{#if canEdit}}
  <button type="button" data-action="deleteItem" data-item-id="{{item.id}}"
          class="icon-btn delete-btn" title="Remove item">
    <i class="fas fa-trash"></i>
  </button>
  {{/if}}

  {{#if canGive}}
  <button type="button" data-action="giveItem" data-item-id="{{item.id}}"
          class="icon-btn give-btn" title="Give item to another player">
    <i class="fas fa-share"></i>
  </button>
  {{/if}}
</div>
