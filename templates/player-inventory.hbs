<div class="player-inventory">
  {{!-- Header with actor name and speed --}}
  <div class="inv-header">
    <h2 class="actor-name">{{actor.name}}</h2>
    <div class="header-speed {{speedColor encumbrance.finalSpeed}}">
      {{encumbrance.finalSpeed}}ft
    </div>
    <button type="button" data-action="openShop" class="btn-toolbar btn-shop" title="Open Shop">
      <i class="fas fa-store"></i> Shop
    </button>
  </div>

  {{!-- Encumbrance bars --}}
  {{> encumbrance-bar encumbrance=encumbrance encMode=encMode}}

  {{!-- Convoy speed indicator (weight mode, when animals are present) --}}
  {{#if (eq encMode "weight")}}
  {{#if encumbrance.animalSpeeds.length}}
  <div class="convoy-speed-bar">
    <span class="convoy-label"><i class="fas fa-route"></i> Convoy Speed:</span>
    {{#each encumbrance.animalSpeeds}}
    <span class="animal-speed-badge {{#if this.isOverCapacity}}speed-red{{else if this.isOverloaded}}speed-orange{{else if (gte this.effectiveSpeed 40)}}speed-green{{else if (gte this.effectiveSpeed 30)}}speed-yellow{{else}}speed-red{{/if}}"
          title="{{this.zoneName}}: {{this.usedWeight}} / {{this.capacity}} wt{{#if this.isOverCapacity}} — over capacity!{{else if this.isOverloaded}} — overloaded (half speed){{/if}}">
      <i class="fas fa-horse"></i> {{this.zoneName}}: {{#if this.isOverCapacity}}—{{else}}{{this.effectiveSpeed}}ft{{/if}}
      {{#if this.isOverloaded}}<i class="fas fa-exclamation-triangle"></i>{{/if}}
      {{#if this.isOverCapacity}}<i class="fas fa-times-circle"></i>{{/if}}
    </span>
    {{/each}}
    {{#if encumbrance.convoySpeed}}
    <span class="convoy-final {{#if (gte encumbrance.convoySpeed 40)}}speed-green{{else if (gte encumbrance.convoySpeed 30)}}speed-yellow{{else if (gte encumbrance.convoySpeed 20)}}speed-orange{{else}}speed-red{{/if}}">
      → {{encumbrance.convoySpeed}}ft
    </span>
    {{/if}}
  </div>
  {{/if}}
  {{/if}}

  {{!-- Coins — total summary only; per-zone purses appear in each zone section below --}}
  <section class="inv-coins">
    <div class="coins-header">
      <h3><i class="fas fa-coins"></i> Coins</h3>
      {{#if isGM}}
      <button type="button" data-action="grantCoins" class="btn-grant-coins" title="Grant coins to this character">
        <i class="fas fa-gift"></i> Grant Coins
      </button>
      {{/if}}
      {{#if canGive}}
      <button type="button" data-action="giveCoins" class="btn-give-coins" title="Give coins to another party member">
        <i class="fas fa-hand-holding-heart"></i> Give Coins
      </button>
      {{/if}}
    </div>
    {{> coin-display inventory=inventory encumbrance=encumbrance canEdit=canEdit}}
  </section>

  {{!-- Weight mode: Unsorted FIRST (before Equipped), then Equipped --}}
  {{#if (eq encMode "weight")}}
  {{#if zones.stowed.length}}
  <section class="inv-zone-section inv-zone-unsorted">
    <div class="zone-header">
      <h3><i class="fas fa-exclamation-triangle"></i> Unsorted</h3>
      <span class="zone-count" style="color:orange;">Move to a container</span>
    </div>
    {{> inventory-zone items=zones.stowed zone="stowed" canEdit=canEdit canGive=canGive isGM=isGM isOwner=isOwner canAddItem=false extraZones=extraZones encMode=encMode}}
  </section>
  {{/if}}
  {{/if}}

  {{!-- Belt Pouch Zone (slot mode only) --}}
  {{#unless (eq encMode "weight")}}
  <section class="inv-zone-section">
    <div class="zone-header">
      <h3><i class="fas fa-gem"></i> Belt Pouch</h3>
      <span class="zone-count {{#if (gt encumbrance.tinyCount 10)}}over-limit{{/if}}">
        {{encumbrance.tinyCount}} / 10
        {{#if (gt encumbrance.tinyOverflow 0)}}
        <span class="overflow-badge" title="{{encumbrance.tinyOverflow}} tiny items overflow into stowed slots">
          +{{encumbrance.tinyOverflow}} overflow
        </span>
        {{/if}}
      </span>
    </div>
    {{> inventory-zone items=zones.tiny zone="tiny" canEdit=canEdit canGive=canGive isGM=isGM isOwner=isOwner canAddItem=canAddItem extraZones=extraZones encMode=encMode}}
    {{> zone-coin-purse zoneId="tiny" zoneCoins=(lookup coinsByZone "tiny") canEdit=canEdit isOwner=isOwner}}
  </section>
  {{/unless}}

  {{!-- Equipped Zone --}}
  <section class="inv-zone-section">
    <div class="zone-header">
      <h3><i class="fas fa-shield-alt"></i> Equipped</h3>
      {{#if (eq encMode "weight")}}
      <span class="zone-count">{{encumbrance.equippedWeight}} wt</span>
      {{else}}
      <span class="zone-count">{{encumbrance.equippedSlots}} slots</span>
      {{/if}}
    </div>
    {{> inventory-zone items=zones.equipped zone="equipped" canEdit=canEdit canGive=canGive isGM=isGM isOwner=isOwner canAddItem=canAddItem extraZones=extraZones encMode=encMode}}
    {{> zone-coin-purse zoneId="equipped" zoneCoins=(lookup coinsByZone "equipped") canEdit=canEdit isOwner=isOwner}}
  </section>

  {{!-- Stowed Zone (slot mode only) --}}
  {{#unless (eq encMode "weight")}}
  <section class="inv-zone-section">
    <div class="zone-header">
      <h3><i class="fas fa-backpack"></i> Stowed</h3>
      <span class="zone-count">{{encumbrance.stowedSlots}} slots
        {{#if (gt encumbrance.coinSlots 0)}}
        <span class="coin-slot-note" title="Includes {{encumbrance.coinSlots}} slot(s) from coins">
          ({{encumbrance.coinSlots}} coins)
        </span>
        {{/if}}
      </span>
    </div>
    {{> inventory-zone items=zones.stowed zone="stowed" canEdit=canEdit canGive=canGive isGM=isGM isOwner=isOwner canAddItem=canAddItem extraZones=extraZones encMode=encMode}}
    {{> zone-coin-purse zoneId="stowed" zoneCoins=(lookup coinsByZone "stowed") canEdit=canEdit isOwner=isOwner}}
  </section>
  {{/unless}}

  {{!-- Storage Zones (weight mode: backpack, sack, etc.) --}}
  {{#if (eq encMode "weight")}}
  {{#each storageZones}}
  <section class="inv-zone-section inv-zone-extra" data-zone-drag-id="{{this.id}}" data-zone-color="{{this.color}}">
    <div class="zone-header zone-header-extra">
      {{#if ../isOwner}}<i class="fas fa-grip-vertical zone-drag-handle" draggable="true" title="Drag to reorder"></i>{{/if}}
      <h3><i class="fas {{#if this.icon}}{{this.icon}}{{else}}fa-backpack{{/if}}"></i> {{this.name}} {{#if this.selfWeight}}<span class="zone-self-weight" title="Container weight">({{this.selfWeight}} wt)</span>{{/if}}</h3>
      <span class="zone-count">{{this.usedWeight}} / {{this.weightCapacity}} wt</span>
    </div>
    {{> extra-zone zone=this canEdit=../canEdit canGive=../canGive isGM=../isGM isOwner=../isOwner extraZones=../extraZones encMode=../encMode}}
    {{> zone-coin-purse zoneId=this.id zoneCoins=(lookup ../coinsByZone this.id) canEdit=../canEdit isOwner=../isOwner}}
  </section>
  {{/each}}
  {{/if}}

  {{!-- Vehicle/Animal Zones --}}
  {{#each vehicleZones}}
  <section class="inv-zone-section inv-zone-extra" data-zone-drag-id="{{this.id}}" data-zone-color="{{this.color}}">
    <div class="zone-header zone-header-extra">
      {{#if ../isOwner}}<i class="fas fa-grip-vertical zone-drag-handle" draggable="true" title="Drag to reorder"></i>{{/if}}
      <h3><i class="fas {{#if this.icon}}{{this.icon}}{{else}}fa-horse{{/if}}"></i> {{this.name}}</h3>
      {{#if (eq ../encMode "weight")}}
      <span class="zone-count">{{this.usedWeight}} / {{this.weightCapacity}} wt</span>
      {{else}}
      <span class="zone-count">{{this.usedSlots}} / {{this.maxSlots}} slots</span>
      {{/if}}
    </div>
    {{!-- Animal info (type, description, speed) --}}
    {{#if this.animalSubcategory}}
    <div class="animal-info-row">
      <span class="animal-type-badge">{{this.animalSubcategory}}</span>
      {{#if this.speedInfo}}
      <span class="animal-speed-badge {{#if this.speedInfo.isOverCapacity}}speed-red{{else if this.speedInfo.isOverloaded}}speed-orange{{else if (gte this.speedInfo.effectiveSpeed 40)}}speed-green{{else if (gte this.speedInfo.effectiveSpeed 30)}}speed-yellow{{else}}speed-red{{/if}}"
            title="Load: {{this.speedInfo.usedWeight}} / {{this.speedInfo.capacity}} wt">
        <i class="fas fa-running"></i>
        {{#if this.speedInfo.isOverCapacity}}
          Overloaded! (cannot move)
        {{else}}
          {{this.speedInfo.effectiveSpeed}}ft
          {{#if this.speedInfo.isOverloaded}}<i class="fas fa-exclamation-triangle" title="Overloaded — half speed"></i>{{/if}}
        {{/if}}
      </span>
      {{/if}}
      {{#if this.animalDescription}}<span class="animal-description">{{this.animalDescription}}</span>{{/if}}
    </div>
    {{/if}}
    {{> extra-zone zone=this canEdit=../canEdit canGive=../canGive isGM=../isGM isOwner=../isOwner extraZones=../extraZones encMode=../encMode}}
    {{> zone-coin-purse zoneId=this.id zoneCoins=(lookup ../coinsByZone this.id) canEdit=../canEdit isOwner=../isOwner}}
  </section>
  {{/each}}

  {{!-- GM button to add a new storage zone (slot mode only) --}}
  {{#if (and isGM (neq encMode "weight"))}}
  <button type="button" data-action="addExtraZone" class="btn-add-extra-zone">
    <i class="fas fa-plus"></i> Add Storage Zone
  </button>
  {{/if}}

  {{!-- Party Gear & Wealth summary --}}
  {{> party-summary partySummary=partySummary}}

  {{!-- GM Transaction Log --}}
  {{#if isGM}}
  {{> transaction-log transactions=transactions}}
  {{/if}}
</div>
